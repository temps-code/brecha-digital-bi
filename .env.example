  # Base de datos Bronze (SQL Server)
  DB_SERVER=localhost,1433
  DB_NAME=BrechaDigitalDB
  # DB_USER=sa  # Solo para Docker o SQL Auth. Dejar vacío para Windows Auth
  # DB_PASSWORD=  # Solo para Docker o SQL Auth. Dejar vacío para Windows Auth

  # Data Warehouse Gold (SQL Server)
  DW_SERVER=localhost,1433
  DW_NAME=DW_BrechaDigital
  # DW_USER=sa  # Solo para Docker o SQL Auth. Dejar vacío para Windows Auth
  # DW_PASSWORD=  # Solo para Docker o SQL Auth. Dejar vacío para Windows Auth

  # Gemini API
  GEMINI_API_KEY=your_gemini_api_key_here

  # Groq API
  GROQ_API_KEY=your_groq_api_key_here

  # Adzuna API
  ADZUNA_APP_ID=your_adzuna_app_id_here
  ADZUNA_API_KEY=your_adzuna_api_key_here
  EOF
